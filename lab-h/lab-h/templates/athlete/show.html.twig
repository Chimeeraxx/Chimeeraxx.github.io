{% extends 'base.html.twig' %}

{% block title %}Szczegóły zawodnika{% endblock %}

{% block body %}
    <div class="card shadow-sm">
        <div class="card-body">
            <h1 class="h3 mb-3">Szczegóły zawodnika</h1>

            <div class="table-responsive">
                <table class="table table-bordered align-middle">
                    <tbody>
                    <tr>
                        <th>ID</th>
                        <td>{{ athlete.id }}</td>
                    </tr>
                    <tr>
                        <th>Nazwa</th>
                        <td>{{ athlete.name }}</td>
                    </tr>
                    <tr>
                        <th>Dyscyplina</th>
                        <td>{{ athlete.sportName }}</td>
                    </tr>
                    <tr>
                        <th>Wiek</th>
                        <td>{{ athlete.age }}</td>
                    </tr>
                    </tbody>
                </table>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <a href="{{ path('app_athlete_index') }}" class="btn btn-outline-secondary">
                    Powrót
                </a>

                <a href="{{ path('app_athlete_edit', {'id': athlete.id}) }}" class="btn btn-primary">
                    Edytuj
                </a>

                {{ include('athlete/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
