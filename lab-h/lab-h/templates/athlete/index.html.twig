{% extends 'base.html.twig' %}

{% block title %}Lista zawodników{% endblock %}

{% block body %}
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                <div>
                    <h1 class="h3 mb-1">Lista zawodników</h1>
                    <p class="text-muted mb-0">Tabela encji Athlete.</p>
                </div>

                <a href="{{ path('app_athlete_new') }}" class="btn btn-primary">
                    Dodaj zawodnika
                </a>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nazwa</th>
                        <th>Dyscyplina</th>
                        <th>Wiek</th>
                        <th>Akcje</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for athlete in athletes %}
                        <tr>
                            <td>{{ athlete.id }}</td>
                            <td>{{ athlete.name }}</td>
                            <td>{{ athlete.sportName }}</td>
                            <td>{{ athlete.age }}</td>
                            <td>
                                <a href="{{ path('app_athlete_show', {'id': athlete.id}) }}" class="btn btn-sm btn-outline-secondary">
                                    Szczegóły
                                </a>

                                <a href="{{ path('app_athlete_edit', {'id': athlete.id}) }}" class="btn btn-sm btn-outline-primary">
                                    Edytuj
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                Brak rekordów.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
